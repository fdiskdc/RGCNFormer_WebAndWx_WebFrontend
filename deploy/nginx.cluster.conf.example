server {
    listen 80;
    server_name cluster.dawdawdawdawfafaawf.xyz;

    # Replace this path with the directory containing the uploaded dist files.
    root /var/www/mrmodn;
    index index.html;

    # The single Flask backend exposes the unified mRModN API.
    location /mrmodn/api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # BrowserRouter routes must fall back to the React entry page.
    location /mrmodn/ {
        try_files $uri $uri/ /mrmodn/index.html;
    }
}
